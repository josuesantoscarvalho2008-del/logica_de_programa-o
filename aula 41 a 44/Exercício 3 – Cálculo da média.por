programa
{
    funcao inicio()
    {
        real n1, n2, media
        escreva("informe o primeiro numero: ")//falta o escreva("")
        leia(n1)
        escreva("informe o segundo numero: ")//falta o escreva("")
        leia(n1)
        leia(n2)

        media = (n1 + n2) / 2 //na média vc divide pela quantidade de elementos e ali tinha apenas 2 elementos e não 3

        escreva("Média: ", media)
    }
}