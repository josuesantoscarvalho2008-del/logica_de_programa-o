programa
{
    funcao inicio()
    {
        inteiro senha
        leia(senha)

        se (senha != 1234)
        {
          escreva("Senha incorreta")// essa função estava invertido com o de baixo
        }
        senao
        {
          escreva("Acesso liberado")// essa função estava invertido com o de cima
        }
    }
}