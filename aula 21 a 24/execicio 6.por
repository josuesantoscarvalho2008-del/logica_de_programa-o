programa {
  funcao inicio() {
    // declaração de variaveis
    cadeia produto
    inteiro quantidade
    real preco
    logico disponivel
    
    produto = "miojo"
    quantidade = 50
    preco = 2.5
    disponivel = verdadeiro
     
    escreva("nome do produto: ", produto, "\n")
    escreva("preço: ", preco, "\n")
    escreva("quntidade: ", quantidade, "\n")
    escreva("O preduto esta disponivel? ", disponivel, "\n")
    


  }
}
